# Frontend Environment Configuration
# Change this URL when deploying to a network or production server

# Development (default - localhost)
# VITE_API_URL=http://localhost:5000

# Production/Network - Replace with your server's IP or domain
# Example: http://192.168.1.100:5000
# Example: http://my-server.example.com:5000
VITE_API_URL=http://localhost:5000
